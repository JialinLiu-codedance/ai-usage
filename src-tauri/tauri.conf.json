{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Usage",
  "version": "0.1.0",
  "identifier": "com.liujialin.ai-usage",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Usage",
        "width": 420,
        "height": 240,
        "minWidth": 420,
        "minHeight": 240,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
